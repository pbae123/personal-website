---
// where projects will be held
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const years = [2026, 2025, 2024];
const byYear = (year: number) => projects.filter((p) => p.data.year === year);
---

<Layout>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <a href="/" class="hover:underline text-[16px] mb-8 block">← Let's go back home</a>
    <h1 class="text-4xl font-bold mb-8">Projects</h1>

    {years.map((year) => (
      <div class="mb-10">
        <h2 class="text-2xl font-semibold mb-4">{year}</h2>
        <hr class="border-t border-gray-300 mb-6" />
        {year === 2024 && (
          <p style="font-size: 22px;">Everyone starts somewhere.</p>
        )}
        <div class="grid gap-6">
          {byYear(year).map((project) => (
            <div class="border border-gray-200 rounded-lg p-6">
              <h2 class="text-xl font-semibold mb-2">
                <a href={`/projects/${project.id}`} class="hover:underline">{project.data.title}</a>
              </h2>
              <p class="text-gray-600 mb-4">{project.data.description}</p>
              <div class="flex gap-2 mb-4">
                {project.data.tags.map((tag) => (
                  <span class="text-sm bg-gray-100 px-2 py-1 rounded">{tag}</span>
                ))}
              </div>
              <div class="flex gap-4">
                {project.data.github && (
                  <a href={project.data.github} class="hover:underline text-sm">GitHub</a>
                )}
                {project.data.demo && (
                  <a href={project.data.demo} class="hover:underline text-sm">Live Demo</a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </main>
</Layout>
