---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-8">Contact</h1>
    <p class="text-gray-600 mb-8">Feel free to reach out or find me on the web.</p>

    <div class="flex flex-col gap-4">
      <a href="mailto:you@email.com" class="text-blue-600 hover:underline">Email</a>
      <a href="https://github.com/yourusername" class="text-blue-600 hover:underline">GitHub</a>
      <a href="https://linkedin.com/in/yourusername" class="text-blue-600 hover:underline">LinkedIn</a>
      <a href="https://beliapp.com/yourusername" class="text-blue-600 hover:underline">Beli</a>
    </div>
  </main>
</Layout>
