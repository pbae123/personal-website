---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <style>body { overflow: hidden; }</style>
  <div class="h-screen flex flex-col max-w-4xl mx-auto px-6 pt-6 pb-0 overflow-hidden">
    <main>
      <h1 class="font-bold text-[36px]"> About Me </h1>
      <p class="mt-4 text-[24px]">I'm Peter, a rising junior at the University of Notre Dame studying CS and Econ.
        I'm passionate about the intersection of tech and business strategy. When offline,
        I'm probably playing tennis, rock climbing, cooking, or exploring new places. Check out some of these links:</p>
      <ul class="list-disc mt-6 space-y-2 pl-15 marker:text-gray-400 [&_a]:underline">
        <li><a href="/projects" class="text-[24px]">Projects</a></li>
        <li><a href="/blog" class="text-[24px]">Thoughts</a></li>
        <li><a href="/places" class="text-[24px]">Places</a></li>
        <li><a href="/contact" class="text-[24px]">Contact</a></li>
      </ul>
    </main>
    <div class="flex-1 flex justify-center items-center" style="mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);">
      <img
        src="/images/nature-scene.png"
        alt="nature scene"
        class="max-h-full max-w-full object-contain mix-blend-multiply"
      />
    </div>
  </div>
</Layout>
