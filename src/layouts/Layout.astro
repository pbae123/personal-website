---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Peter Bae</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <script is:inline>
      // apply saved theme before paint to avoid flash
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') document.documentElement.classList.add('dark');
    </script>
  </head>
  <body>
    <header class="max-w-4xl mx-auto px-6 pt-14 pb-6 flex items-center justify-between">
      <a href="/" class="text-[26px]">Peter Bae</a>
      <nav class="flex items-center gap-6">
        <a href="/" class="text-[26px]">About</a>
        <a href="/blog" class="text-[26px]">Thoughts</a>
        <ThemeToggle client:load />
      </nav>
    </header>
    <hr class="w-[850px] mx-auto border-t border-black -mt-3" /> 

    <slot />
  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  html.dark body {
    background-color: #100F0F;
    color: #FFFCF0;
  }
</style>
